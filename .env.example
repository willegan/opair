# Supabase project URL (from your Supabase project settings)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon/public key (safe to expose to browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key (NEVER expose to browser — server-side only)
# Used for admin operations that bypass Row-Level Security
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
